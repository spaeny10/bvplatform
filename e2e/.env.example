# Copy to .env (gitignored) and fill in. All values are read by
# playwright.config.ts (dotenv) and scripts/registry-status.mjs.

# Base URL the tests hit. Default targets the SSH tunnel opened by
# scripts/tunnel-bob.ps1 / .sh (local 13000 -> bob 192.168.103.48:3000).
# Phase-2 CI on fred will set this to http://192.168.103.48:3000 directly.
IRONSIGHT_BASE_URL=http://127.0.0.1:13000

# Admin password of the bob TEST deploy. Retrieve with:
#   ssh fred
#   ssh jetstream@192.168.103.48 'sudo grep ADMIN_PASSWORD /etc/ironsight-test/db.env'
# REQUIRED — the setup project hard-fails without a working admin login.
IRONSIGHT_ADMIN_PASSWORD=

# Password for the seeded demo users (rmorgan / jhayes / marcus.webb /
# spierce). Defaults to demo123 when unset. If these users 401, run the
# seed (see README) — the harness soft-skips those roles otherwise.
IRONSIGHT_DEMO_PASSWORD=demo123

# Optional browser channel. Set to "chrome" to run against installed
# branded Chrome (enables HEVC decode -> Tier-2 video assertions can pass).
# Unset = Playwright's bundled Chromium.
#PW_CHANNEL=chrome

# Set to 1 only when the browser in use can actually decode HEVC
# (e.g. PW_CHANNEL=chrome on a host with HW decode). Turns on Tier-2
# assertions: video.currentTime must advance and readyState>=2.
#IRONSIGHT_EXPECT_DECODE=1
