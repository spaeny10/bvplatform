# ─────────────────────────────────────────────────────────────────
# Ironsight — docker-compose secrets and knobs.
#
# Copy this file to `.env` and fill in the values marked REQUIRED.
# `.env` is gitignored by convention — never commit real secrets.
#
# Generate cryptographic secrets on a Linux/Mac host:
#   openssl rand -hex 32        → JWT_SECRET
#   openssl rand -base64 24     → ADMIN_PASSWORD
# ─────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────
POSTGRES_DB=onvif_tool
POSTGRES_USER=onvif
# REQUIRED. Anything ≥16 chars, not a dictionary word. Rotate on incident.
POSTGRES_PASSWORD=CHANGEME_strong_db_password

# ── API secrets ─────────────────────────────────────────────────
# REQUIRED. Rotating this invalidates every existing JWT, which is a fine
# emergency break-glass.
JWT_SECRET=CHANGEME_hex_32_bytes_openssl_rand_hex_32

# REQUIRED. Password for the auto-created `admin` user on first boot.
# Ignored on subsequent starts — change the password via the UI or
# directly in the users table.
ADMIN_PASSWORD=CHANGEME_first_run_admin_password

# ── Host port mapping ───────────────────────────────────────────
# Edit these if something else on the host already owns these ports.
FRONTEND_PORT=3000
API_PORT=8080
MEDIAMTX_RTSP_PORT=8554
MEDIAMTX_WEBRTC_PORT=8889

# ── AI services ─────────────────────────────────────────────────
# Set to `false` to disable the Qwen/YOLO pipeline entirely (useful if
# you don't have GPU hosts yet).
AI_ENABLED=true

# Image tags. `localhost/...` is the Podman convention for locally-built
# images (don't attempt a registry pull). Docker treats the prefix as
# part of the tag — both work.
YOLO_IMAGE=localhost/ironsight/yolo:latest
QWEN_IMAGE=localhost/ironsight/qwen:latest
YOLO_MODEL=yolov8n
QWEN_MODEL=Qwen2-VL-2B-Instruct

# GPU assignment for the AI services. With two 3070s:
#   YOLO on GPU 0 (event-triggered, latency-sensitive)
#   Qwen on GPU 1 (batch indexer, throughput-biased)
# If you only have one GPU, set both to 0. Match values to what
# `nvidia-smi` shows on the host.
#
# The compose file uses `CUDA_VISIBLE_DEVICES` to filter per-service,
# not CDI device names or NVIDIA_VISIBLE_DEVICES. WSL exposes every
# physical GPU through a single virtual /dev/dxg node, so neither the
# nvidia.com/gpu=<index> CDI pattern nor NVIDIA_VISIBLE_DEVICES can
# mask at the device layer. CUDA_VISIBLE_DEVICES filters inside the
# CUDA runtime and works the same on WSL and native Linux.
#
# CDI spec generation is a one-time host setup:
#   sudo nvidia-ctk cdi generate --output=/etc/cdi/nvidia.yaml
#
# If `nvidia-ctk cdi list` reports "conflicting device nvidia.com/gpu=all"
# and 0 devices, you have both nvidia.yaml and nvidia.json in /etc/cdi.
# Delete one (keep the YAML we generate above).
YOLO_GPU_INDEX=0
QWEN_GPU_INDEX=1

# ── Recording ───────────────────────────────────────────────────
# Target segment duration in seconds. 60 is a sensible default — shorter
# segments give finer seek granularity at the cost of more files in the
# recordings dir. Changing this requires no migration.
SEGMENT_DURATION=60

# ── Public URL override ─────────────────────────────────────────
# Set when the API sits behind a reverse proxy on a different hostname
# than the frontend. Same-origin deployments can leave this as /api.
NEXT_PUBLIC_API_BASE=/api

# ── Image tagging (optional) ────────────────────────────────────
# Bump when you cut a release so `docker compose pull` pulls the right
# version. Leave as `latest` during active development.
IRONSIGHT_VERSION=latest

# ── Branding ─────────────────────────────────────────────────────
# User-visible product name used in backend output (evidence-export
# README headers, log prefixes). The frontend has its own source of
# truth in src/lib/branding.ts — keep them in sync when rebranding.
# See Documents/Rebrand.md for the full checklist.
PRODUCT_NAME=Ironsight

# ── Worker split ────────────────────────────────────────────────
# In docker-compose production, batch jobs (retention, VLM indexer,
# export worker) run in the `worker` service container, not in `api`.
# RUN_WORKERS_API toggles whether the api container also runs them.
#
#   false (default)  — api runs HTTP only; worker container owns jobs
#   true             — api runs everything in-process; skip `worker` service
#                      (useful for a single-box all-in-one deployment)
RUN_WORKERS_API=false

# ── Scale-out (optional) ────────────────────────────────────────
# When running multiple `api` replicas, a Redis pub/sub bridge fans
# out WebSocket events across them. Leave REDIS_URL empty for a
# single-replica deployment — the in-memory hub handles everything.
#
# To enable:
#   1. Bring up the Redis service:  docker compose --profile scale-out up -d
#   2. Uncomment and set:
# REDIS_URL=redis://redis:6379/0
# REDIS_WS_CHANNEL=ironsight:ws:broadcast
